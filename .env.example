PORT=
NODE_ENV=
APP_NAME=

# Socket.IO — admin join (emit "admin:join" với payload = secret)
ADMIN_SOCKET_SECRET=
# User join room `user:${userId}` (emit "user:join" với { userId, token })
USER_SOCKET_SECRET=

# SURREALDB
SURREAL_URL=
SURREAL_NAMESPACE=
SURREAL_DATABASE=
# SURREAL_USERNAME=
SURREAL_USERNAME=
# SURREAL_PASSWORD=
SURREAL_PASSWORD=

# Redis — Socket.IO adapter (pub/sub khi scale nhiều instance). Để trống nếu chỉ 1 process.
REDIS_URL=
# REDIS_SOCKET_IO_KEY=socket.io

PUBLIC_KEY=

PRIVATE_KEY=