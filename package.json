{
  "name": "chat-community",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outdir=dist --packages=external",
    "type-check": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "prod": "cross-env NODE_ENV=production npm run build && node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint-fix": "eslint src --fix && prettier --write src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baolh106/Chat-Community.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/baolh106/Chat-Community/issues"
  },
  "homepage": "https://github.com/baolh106/Chat-Community#readme",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.13.6",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "surrealdb": "^2.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "cross-env": "^7.0.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
